// FIR408 GUI capture: Test Tone sine-frequency selector byte via real GUI action.
// This script intentionally does not open a DSP control session, because that can
// disconnect the vendor GUI. Run a separate readback script after GUI capture.
// Assumption before run: Sine Wave is selected and the frequency is at 20KHz.

let tag = "testtone-sine-frequency-gui-readback-fir408";
let base = "out/gui-read-decode/${tag}";

connect();
guiConnect();
clearFrames();
let cap = guiActionCapture("Test Tone: Sine Wave aktiv lassen und nur die Frequenz auf 20Hz setzen.", 90000, 1500, 8000);

let cmd39Writes = writesByCommand(cap, 0x39);
let offsets = changingOffsetsAcrossWrites(cmd39Writes);
let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 20, 0x40);

saveText("${base}/capture.txt", cap);
saveText("${base}/cmd39-writes.txt", cmd39Writes);
saveText("${base}/cmd39-payloads.txt", payloadSeries(cmd39Writes));
saveText("${base}/cmd39-changing-offsets.txt", offsets);
saveText("${base}/last-write.txt", last);
saveText("${base}/recent-interesting-writes.txt", recent);

print("testtone-sine-frequency-gui-capture-fir408 done");
print("Saved to: ${base}");
print(offsets);
print(last);
