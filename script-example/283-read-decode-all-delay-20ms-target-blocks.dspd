# Confirm FIR408 delay u16 start offsets with a non-zero low byte (20.0 ms = raw 1920 = 0x0780).
# Blocks come from the all-block 0 -> 680 ms search in script 282.

let base = "out/read-decode/all-delay-20ms-target-blocks";

connect();
resetSession();
ensureSession();
handshake();

let inaMin = "00 01 04 38 00 00 00";
let ina20 = "00 01 04 38 00 80 07";
let inbMin = "00 01 04 38 01 00 00";
let inb20 = "00 01 04 38 01 80 07";
let incMin = "00 01 04 38 02 00 00";
let inc20 = "00 01 04 38 02 80 07";
let indMin = "00 01 04 38 03 00 00";
let ind20 = "00 01 04 38 03 80 07";
let out1Min = "00 01 04 38 04 00 00";
let out1Max = "00 01 04 38 04 00 FF";
let out1_20 = "00 01 04 38 04 80 07";
let out2Max = "00 01 04 38 05 00 FF";
let out2Min = "00 01 04 38 05 00 00";
let out2_20 = "00 01 04 38 05 80 07";
let out3Min = "00 01 04 38 06 00 00";
let out3_20 = "00 01 04 38 06 80 07";
let out4Max = "00 01 04 38 07 00 FF";
let out4Min = "00 01 04 38 07 00 00";
let out4_20 = "00 01 04 38 07 80 07";
let out5Min = "00 01 04 38 08 00 00";
let out5_20 = "00 01 04 38 08 80 07";
let out6Max = "00 01 04 38 09 00 FF";
let out6Min = "00 01 04 38 09 00 00";
let out6_20 = "00 01 04 38 09 80 07";
let out7Min = "00 01 04 38 0A 00 00";
let out7_20 = "00 01 04 38 0A 80 07";
let out8Max = "00 01 04 38 0B 00 FF";
let out8Min = "00 01 04 38 0B 00 00";
let out8_20 = "00 01 04 38 0B 80 07";

saveText("${base}/pattern-summary.txt",
    "Delay 20ms target-block confirmation\nmin raw=0 = 0.000 ms\n20ms raw=1920 = 0x0780\n"
);

write(inaMin);
sleep(150);
let beforeIna = readBlock(3);
write(ina20);
sleep(150);
let afterIna = readBlock(3);
saveText("${base}/ina/block-3-before.hex.txt", beforeIna.payloadHex);
saveText("${base}/ina/block-3-after.hex.txt", afterIna.payloadHex);
saveText("${base}/ina/block-3-changed-offsets.txt", changedOffsets(beforeIna.payload, afterIna.payload));
saveText("${base}/ina/block-3-diff-u16le.txt", diffU16le(beforeIna.payload, afterIna.payload));
saveDiffReport("${base}/ina/block-3-diff-report.txt", beforeIna.payload, afterIna.payload);
print("ina block 3");
print(changedOffsets(beforeIna.payload, afterIna.payload));

write(inbMin);
sleep(150);
let beforeInb = readBlock(5);
write(inb20);
sleep(150);
let afterInb = readBlock(5);
