print(changedOffsets(beforeOut8.payload, afterOut8.payload));

# Restore the alternating min/max state shown in the user's delay screenshot.
write(inaMin);
write("00 01 04 38 01 00 FF");
write(incMin);
write("00 01 04 38 03 00 FF");
write(out1Min);
write("00 01 04 38 05 00 FF");
write(out3Min);
write("00 01 04 38 07 00 FF");
write(out5Min);
write("00 01 04 38 09 00 FF");
write(out7Min);
write("00 01 04 38 0B 00 FF");

print("all-delay-20ms-target-blocks-done");
