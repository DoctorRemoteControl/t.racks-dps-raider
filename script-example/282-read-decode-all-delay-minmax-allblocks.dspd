# Decode FIR408 delay readback locations for InA..InD and Out1..Out8 by controlled min -> max writes.

let base = "out/read-decode/all-delay-minmax";

connect();
resetSession();
ensureSession();
handshake();

let inaMin = "00 01 04 38 00 00 00";
let inaMax = "00 01 04 38 00 00 FF";
let inbMin = "00 01 04 38 01 00 00";
let inbMax = "00 01 04 38 01 00 FF";
let incMin = "00 01 04 38 02 00 00";
let incMax = "00 01 04 38 02 00 FF";
let indMin = "00 01 04 38 03 00 00";
let indMax = "00 01 04 38 03 00 FF";
let out1Min = "00 01 04 38 04 00 00";
let out1Max = "00 01 04 38 04 00 FF";
let out2Min = "00 01 04 38 05 00 00";
let out2Max = "00 01 04 38 05 00 FF";
let out3Min = "00 01 04 38 06 00 00";
let out3Max = "00 01 04 38 06 00 FF";
let out4Min = "00 01 04 38 07 00 00";
let out4Max = "00 01 04 38 07 00 FF";
let out5Min = "00 01 04 38 08 00 00";
let out5Max = "00 01 04 38 08 00 FF";
let out6Min = "00 01 04 38 09 00 00";
let out6Max = "00 01 04 38 09 00 FF";
let out7Min = "00 01 04 38 0A 00 00";
let out7Max = "00 01 04 38 0A 00 FF";
let out8Min = "00 01 04 38 0B 00 00";
let out8Max = "00 01 04 38 0B 00 FF";

saveText("${base}/pattern-summary.txt",
    "Delay min/max read decode for InA..InD and Out1..Out8\nmin: raw=0 = 0.000 ms\nmax: raw=65280 = 680.000 ms\nInA min=${inaMin}\nInA max=${inaMax}\nInB min=${inbMin}\nInB max=${inbMax}\nInC min=${incMin}\nInC max=${incMax}\nInD min=${indMin}\nInD max=${indMax}\nOut1 min=${out1Min}\nOut1 max=${out1Max}\nOut2 min=${out2Min}\nOut2 max=${out2Max}\nOut3 min=${out3Min}\nOut3 max=${out3Max}\nOut4 min=${out4Min}\nOut4 max=${out4Max}\nOut5 min=${out5Min}\nOut5 max=${out5Max}\nOut6 min=${out6Min}\nOut6 max=${out6Max}\nOut7 min=${out7Min}\nOut7 max=${out7Max}\nOut8 min=${out8Min}\nOut8 max=${out8Max}\n"
);

for (let i in 0..28) {
    write(inaMin);
    sleep(120);
    let before = readBlock(i);
    write(inaMax);
    sleep(120);
    let after = readBlock(i);
    let offsets = changedOffsets(before.payload, after.payload);
    if (len(offsets) > 0) {
        saveText("${base}/ina/block-${i}-before.hex.txt", before.payloadHex);
        saveText("${base}/ina/block-${i}-after.hex.txt", after.payloadHex);
        saveText("${base}/ina/block-${i}-changed-offsets.txt", offsets);
        saveText("${base}/ina/block-${i}-diff-bytes.txt", diffBytes(before.payload, after.payload));
        saveText("${base}/ina/block-${i}-diff-u16le.txt", diffU16le(before.payload, after.payload));
        saveDiffReport("${base}/ina/block-${i}-diff-report.txt", before.payload, after.payload);
        print("ina changed-block ${i}");
        print(offsets);
    }
}

