let tag = "out1-limit-threshold-series";
let base = "out/fader/${tag}";
let control = "threshold";
let command = 0x3F;
let channel = 0x04;

guiConnect();

let cap = guiActionCapture(
    "On the Limit page, move only the Out1 Threshold fader slowly across several positions now.",
    60000,
    3000,
    15000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 60, 0x40);
let limitAll = writesByCommand(cap, command);
let series = writesByCommandAndChannel(cap, command, channel);

let frames = cap.totalFrames;
let writes = cap.writeCount;
let responses = cap.responseCount;
let allCount = len(limitAll);
let seriesCount = len(series);
let offsets = changingOffsetsAcrossWrites(series);
let allOffsets = changingOffsetsAcrossWrites(limitAll);

saveText("${base}/summary.txt",
    "tag=${tag}\ncontrol=${control}\ncommand=0x3F\nchannel=0x04\nframes=${frames}\nwrites=${writes}\nresponses=${responses}\nlimitAll=${allCount}\nseriesCount=${seriesCount}\nchangingOffsets=${offsets}\nallLimitChangingOffsets=${allOffsets}\nlastInteresting=${last}\n"
);

saveText("${base}/last-write.txt", last);
saveText("${base}/recent-interesting-writes.txt", recent);
saveText("${base}/limit-all-payload-series.txt", payloadSeries(limitAll));
saveText("${base}/limit-all-changing-offsets.txt", allOffsets);
saveText("${base}/limit-out1-payload-series.txt", payloadSeries(series));
saveText("${base}/limit-out1-changing-offsets.txt", offsets);
saveText("${base}/limit-out1-u16-at-5.txt", u16Series(series, 5));
saveText("${base}/limit-out1-u16-at-7.txt", u16Series(series, 7));
saveText("${base}/limit-out1-u16-at-9.txt", u16Series(series, 9));
saveText("${base}/limit-out1-u16-at-11.txt", u16Series(series, 11));
saveText("${base}/limit-out1-u16-at-13.txt", u16Series(series, 13));

print("done");
print("saved=${base}");
print("seriesCount=${seriesCount}");
print(offsets);
