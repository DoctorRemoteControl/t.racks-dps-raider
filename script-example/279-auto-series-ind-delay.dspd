let tag = "ind-delay-series";
let base = "out/fader/${tag}";
let control = "delay";
let command = 0x38;
let channel = 0x03;

guiConnect();

let cap = guiActionCapture(
    "On the Delay page, move only the InD Delay fader slowly across several positions now. Leave the unit on ms.",
    60000,
    3000,
    15000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 60, 0x40);
let delayAll = writesByCommand(cap, command);
let series = writesByCommandAndChannel(cap, command, channel);

let frames = cap.totalFrames;
let writes = cap.writeCount;
let responses = cap.responseCount;
let allCount = len(delayAll);
let seriesCount = len(series);
let offsets = changingOffsetsAcrossWrites(series);
let allOffsets = changingOffsetsAcrossWrites(delayAll);

saveText("${base}/summary.txt",
    "tag=${tag}\ncontrol=${control}\ncommand=0x38\nchannel=0x03\nframes=${frames}\nwrites=${writes}\nresponses=${responses}\ndelayAll=${allCount}\nseriesCount=${seriesCount}\nchangingOffsets=${offsets}\nallDelayChangingOffsets=${allOffsets}\nlastInteresting=${last}\n"
);

saveText("${base}/last-write.txt", last);
saveText("${base}/recent-interesting-writes.txt", recent);
saveText("${base}/delay-all-payload-series.txt", payloadSeries(delayAll));
saveText("${base}/delay-all-changing-offsets.txt", allOffsets);
saveText("${base}/delay-ind-payload-series.txt", payloadSeries(series));
saveText("${base}/delay-ind-changing-offsets.txt", offsets);
saveText("${base}/delay-ind-u16-at-5.txt", u16Series(series, 5));

print("done");
print("saved=${base}");
print("seriesCount=${seriesCount}");
print(offsets);
