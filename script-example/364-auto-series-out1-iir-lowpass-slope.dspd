let tag = "out1-iir-lowpass-slope-series";
let base = "out/fader/${tag}";
let command = 0x31;
let channel = 0x04;

guiConnect();

let cap = guiActionCapture(
    "On the Out1 Crossover/IIR page, change only the LowPass slope selector through several values now. Leave frequency and bypass unchanged.",
    60000,
    3000,
    15000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 80, 0x40);
let all = writesByCommand(cap, command);
let series = writesByCommandAndChannel(cap, command, channel);
let offsets = changingOffsetsAcrossWrites(series);
let allCount = len(all);
let seriesCount = len(series);

saveText("${base}/summary.txt",
    "tag=${tag}\ncontrol=lowpass_slope\ncommand=0x31\nchannel=0x04\nexpectedOffset=7\nframes=${cap.totalFrames}\nwrites=${cap.writeCount}\nresponses=${cap.responseCount}\nallCommandCount=${allCount}\nseriesCount=${seriesCount}\nchangingOffsets=${offsets}\nlastInteresting=${last}\n"
);
saveText("${base}/last-write.txt", last);
saveText("${base}/recent-interesting-writes.txt", recent);
saveText("${base}/payload-series.txt", payloadSeries(series));
saveText("${base}/changing-offsets.txt", offsets);
saveText("${base}/u16-at-5.txt", u16Series(series, 5));
saveText("${base}/u16-at-6.txt", u16Series(series, 6));
saveText("${base}/u16-at-7.txt", u16Series(series, 7));

print("done");
print("saved=${base}");
print("seriesCount=${seriesCount}");
print(offsets);
