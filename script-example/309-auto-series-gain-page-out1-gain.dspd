let tag = "gain-page-out1-gain-series";
let base = "out/fader/${tag}";
let control = "gain";
let command = 0x34;
let channel = 0x04;

guiConnect();

let cap = guiActionCapture(
    "On the Gain page, move only the Out1 Gain fader across several positions now.",
    60000,
    3000,
    15000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 60, 0x40);
let gainAll = writesByCommand(cap, command);
let series = writesByCommandAndChannel(cap, command, channel);

let frames = cap.totalFrames;
let writes = cap.writeCount;
let responses = cap.responseCount;
let gainAllCount = len(gainAll);
let seriesCount = len(series);
let offsets = changingOffsetsAcrossWrites(series);
let allOffsets = changingOffsetsAcrossWrites(gainAll);

saveText("${base}/summary.txt",
    "tag=${tag}\ncontrol=${control}\ncommand=0x34\nchannel=0x04\nframes=${frames}\nwrites=${writes}\nresponses=${responses}\ngainAll=${gainAllCount}\nseriesCount=${seriesCount}\nchangingOffsets=${offsets}\nallGainChangingOffsets=${allOffsets}\nlastInteresting=${last}\n"
);

saveText("${base}/last-write.txt", last);
saveText("${base}/recent-interesting-writes.txt", recent);
saveText("${base}/gain-all-payload-series.txt", payloadSeries(gainAll));
saveText("${base}/gain-all-changing-offsets.txt", allOffsets);
saveText("${base}/gain-out1-payload-series.txt", payloadSeries(series));
saveText("${base}/gain-out1-changing-offsets.txt", offsets);
saveText("${base}/gain-out1-u16-at-5.txt", u16Series(series, 5));

print("done");
print("saved=${base}");
print("seriesCount=${seriesCount}");
print(offsets);
