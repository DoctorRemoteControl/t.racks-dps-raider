# Decode InA PEQ readback storage by writing a known baseline,
# then a unique pattern across PEQ1..PEQ8, then an alternating bypass bitmask.

let base = "out/read-decode/ina-peq-allbands-pattern";

connect();
resetSession();
ensureSession();
handshake();

# Baseline: all bands Gain 0.0 dB (0x0078), Q 3.00 (0x23), Type Peak (0x00), Bypass off (0x00).
let peq1Base = "00 01 0A 33 00 00 78 00 18 00 23 00 00";
let peq2Base = "00 01 0A 33 00 01 78 00 47 00 23 00 00";
let peq3Base = "00 01 0A 33 00 02 78 00 65 00 23 00 00";
let peq4Base = "00 01 0A 33 00 03 78 00 8C 00 23 00 00";
let peq5Base = "00 01 0A 33 00 04 78 00 AA 00 23 00 00";
let peq6Base = "00 01 0A 33 00 05 78 00 C8 00 23 00 00";
let peq7Base = "00 01 0A 33 00 06 78 00 F0 00 23 00 00";
let peq8Base = "00 01 0A 33 00 07 78 00 2C 01 23 00 00";

# Unique pattern: all visible fields differ from baseline.
let peq1Pattern = "00 01 0A 33 00 00 5A 00 0A 00 0A 01 00";
let peq2Pattern = "00 01 0A 33 00 01 69 00 2D 00 14 02 00";
let peq3Pattern = "00 01 0A 33 00 02 87 00 50 00 1E 03 00";
let peq4Pattern = "00 01 0A 33 00 03 96 00 73 00 28 04 00";
let peq5Pattern = "00 01 0A 33 00 04 A5 00 96 00 32 05 00";
let peq6Pattern = "00 01 0A 33 00 05 B4 00 B9 00 3C 06 00";
let peq7Pattern = "00 01 0A 33 00 06 C3 00 DC 00 46 07 00";
let peq8Pattern = "00 01 0A 33 00 07 D2 00 FF 00 50 08 00";

# Same pattern, but PEQ2/4/6/8 bypass on. Expected bitmask is 0xAA if PEQ1 is bit0.
let peq1BypassPattern = "00 01 0A 33 00 00 5A 00 0A 00 0A 01 00";
let peq2BypassPattern = "00 01 0A 33 00 01 69 00 2D 00 14 02 01";
let peq3BypassPattern = "00 01 0A 33 00 02 87 00 50 00 1E 03 00";
let peq4BypassPattern = "00 01 0A 33 00 03 96 00 73 00 28 04 01";
let peq5BypassPattern = "00 01 0A 33 00 04 A5 00 96 00 32 05 00";
let peq6BypassPattern = "00 01 0A 33 00 05 B4 00 B9 00 3C 06 01";
let peq7BypassPattern = "00 01 0A 33 00 06 C3 00 DC 00 46 07 00";
let peq8BypassPattern = "00 01 0A 33 00 07 D2 00 FF 00 50 08 01";

saveText("${base}/pattern-summary.txt",
    "InA PEQ all-band read decode\n"
    + "Baseline: gain=0x0078, Q=0x23, Type=0x00, Bypass=0x00, default-ish frequency spread\n"
    + "Pattern: PEQ1..PEQ8 use unique gain/frequency/Q/type bytes, Bypass=0x00\n"
    + "Bypass pattern: same unique values, PEQ2/4/6/8 bypass on; expected read bitmask 0xAA\n"
    + "PEQ1 base=${peq1Base}\nPEQ1 pattern=${peq1Pattern}\n"
    + "PEQ8 base=${peq8Base}\nPEQ8 pattern=${peq8Pattern}\n"
);

write(peq1Base); write(peq2Base); write(peq3Base); write(peq4Base);
write(peq5Base); write(peq6Base); write(peq7Base); write(peq8Base);
sleep(300);

for (let i in 0..28) {
    let block = readBlock(i);
    saveText("${base}/baseline/block-${i}.hex.txt", block.payloadHex);
}

let before1 = readBlock(1);
let before2 = readBlock(2);
let before28 = readBlock(28);

write(peq1Pattern); write(peq2Pattern); write(peq3Pattern); write(peq4Pattern);
write(peq5Pattern); write(peq6Pattern); write(peq7Pattern); write(peq8Pattern);
sleep(300);

for (let i in 0..28) {
    let block = readBlock(i);
    saveText("${base}/pattern/block-${i}.hex.txt", block.payloadHex);
}

let after1 = readBlock(1);
let after2 = readBlock(2);
let after28 = readBlock(28);

saveText("${base}/value-pattern/block-1-before.hex.txt", before1.payloadHex);
saveText("${base}/value-pattern/block-1-after.hex.txt", after1.payloadHex);
saveText("${base}/value-pattern/block-1-changed-offsets.txt", changedOffsets(before1.payload, after1.payload));
saveText("${base}/value-pattern/block-1-diff-bytes.txt", diffBytes(before1.payload, after1.payload));
saveText("${base}/value-pattern/block-1-diff-u16le.txt", diffU16le(before1.payload, after1.payload));
saveDiffReport("${base}/value-pattern/block-1-diff-report.txt", before1.payload, after1.payload);

saveText("${base}/value-pattern/block-2-before.hex.txt", before2.payloadHex);
saveText("${base}/value-pattern/block-2-after.hex.txt", after2.payloadHex);
saveText("${base}/value-pattern/block-2-changed-offsets.txt", changedOffsets(before2.payload, after2.payload));
saveText("${base}/value-pattern/block-2-diff-bytes.txt", diffBytes(before2.payload, after2.payload));
saveText("${base}/value-pattern/block-2-diff-u16le.txt", diffU16le(before2.payload, after2.payload));
saveDiffReport("${base}/value-pattern/block-2-diff-report.txt", before2.payload, after2.payload);

saveText("${base}/value-pattern/block-28-before.hex.txt", before28.payloadHex);
saveText("${base}/value-pattern/block-28-after.hex.txt", after28.payloadHex);
saveText("${base}/value-pattern/block-28-changed-offsets.txt", changedOffsets(before28.payload, after28.payload));
saveText("${base}/value-pattern/block-28-diff-bytes.txt", diffBytes(before28.payload, after28.payload));
saveText("${base}/value-pattern/block-28-diff-u16le.txt", diffU16le(before28.payload, after28.payload));
saveDiffReport("${base}/value-pattern/block-28-diff-report.txt", before28.payload, after28.payload);

let beforeBypass = readBlock(28);
write(peq1BypassPattern); write(peq2BypassPattern); write(peq3BypassPattern); write(peq4BypassPattern);
write(peq5BypassPattern); write(peq6BypassPattern); write(peq7BypassPattern); write(peq8BypassPattern);
sleep(300);
let afterBypass = readBlock(28);

saveText("${base}/bypass-pattern/block-28-before.hex.txt", beforeBypass.payloadHex);
saveText("${base}/bypass-pattern/block-28-after.hex.txt", afterBypass.payloadHex);
saveText("${base}/bypass-pattern/block-28-changed-offsets.txt", changedOffsets(beforeBypass.payload, afterBypass.payload));
saveText("${base}/bypass-pattern/block-28-diff-bytes.txt", diffBytes(beforeBypass.payload, afterBypass.payload));
saveText("${base}/bypass-pattern/block-28-diff-u16le.txt", diffU16le(beforeBypass.payload, afterBypass.payload));
saveDiffReport("${base}/bypass-pattern/block-28-diff-report.txt", beforeBypass.payload, afterBypass.payload);

# Restore the PEQ state shown in the user screenshot.
write(peq1Base); write(peq2Base); write(peq3Base); write(peq4Base);
write(peq5Base); write(peq6Base); write(peq7Base); write(peq8Base);

print("ina-peq-allbands-pattern-read-decode-done");
print("value-pattern block1 offsets");
print(changedOffsets(before1.payload, after1.payload));
print("value-pattern block2 offsets");
print(changedOffsets(before2.payload, after2.payload));
print("bypass-pattern block28 offsets");
print(changedOffsets(beforeBypass.payload, afterBypass.payload));
