// Fresh GUI capture: Out1 FIR crossover LowPass frequency fader.
// User action: move only the LowPass fader from high to low and back.

let tag = "out1-fir-lowpass-frequency-fresh";
let base = "out/fir/${tag}";
let command = 0x4B;
let channel = 0x04;

guiConnect();

let cap = guiActionCapture("Out1 FIR Crossover: LowPass auf mehrere Werte stellen und nach jedem Wert OK druecken. HighPass/Type/Win/Taps nicht aendern.", 120000, 10000, 30000);

let all = writesByCommand(cap, command);
let series = writesByCommandAndChannel(cap, command, channel);
let count = len(series);
let offsets = changingOffsetsAcrossWrites(series);

saveText("${base}/capture.txt", cap);
saveText("${base}/all-4b-writes.txt", all);
saveText("${base}/out1-4b-writes.txt", series);
saveText("${base}/out1-4b-payloads.txt", payloadSeries(series));
saveText("${base}/out1-4b-changing-offsets.txt", offsets);
saveText("${base}/out1-u16-at-5.txt", u16Series(series, 5));
saveText("${base}/out1-u16-at-6.txt", u16Series(series, 6));
saveText("${base}/out1-highpass-u16-series.txt", u16Series(series, 7));
saveText("${base}/out1-lowpass-u16-series.txt", u16Series(series, 9));
saveText("${base}/out1-taps-u16-series.txt", u16Series(series, 11));

print("Out1 FIR LowPass frequency capture done");
print("Out1 0x4B writes: ${count}");
print("Saved to: ${base}");
print(offsets);
