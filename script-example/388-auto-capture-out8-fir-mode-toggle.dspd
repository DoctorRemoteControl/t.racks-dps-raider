// Fresh GUI capture: Out8 crossover FIR mode selector.
// User action: switch Out8 Mode to FIR, or IIR -> FIR -> IIR -> FIR if it is already FIR.

let tag = "out8-fir-mode-toggle-fresh";
let base = "out/fir/${tag}";
let command = 0x4C;
let channel = 0x0B;

guiConnect();

let cap = guiActionCapture("Out8 Crossover: Mode am Out8 einmal auf FIR bringen. Falls schon FIR: kurz IIR und direkt zurueck FIR.", 90000, 3000, 15000);

let all = writesByCommand(cap, command);
let series = writesByCommandAndChannel(cap, command, channel);
let count = len(series);
let offsets = changingOffsetsAcrossWrites(series);

saveText("${base}/capture.txt", cap);
saveText("${base}/all-4c-writes.txt", all);
saveText("${base}/out8-4c-writes.txt", series);
saveText("${base}/out8-4c-payloads.txt", payloadSeries(series));
saveText("${base}/out8-4c-changing-offsets.txt", offsets);
saveText("${base}/out8-4c-u16-at-4.txt", u16Series(series, 4));

print("Out8 FIR mode toggle capture done");
print("Out8 0x4C writes: ${count}");
print("Saved to: ${base}");
print(offsets);
