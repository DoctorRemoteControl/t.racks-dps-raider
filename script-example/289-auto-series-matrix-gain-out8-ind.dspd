let tag = "matrix-gain-out8-ind-series-v2";
let base = "out/fader/${tag}";
let control = "matrix_gain";
let command = 0x41;
let output = 0x0B;

guiConnect();

let cap = guiActionCapture(
    "On the Matrix page, move only the Out8 <- InD gain fader across several values.",
    60000,
    3000,
    15000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 60, 0x40);
let gainAll = writesByCommand(cap, command);
let series = writesByCommandAndChannel(cap, command, output);

let frames = cap.totalFrames;
let writes = cap.writeCount;
let responses = cap.responseCount;
let allCount = len(gainAll);
let seriesCount = len(series);
let offsets = changingOffsetsAcrossWrites(series);
let allOffsets = changingOffsetsAcrossWrites(gainAll);

saveText("${base}/summary.txt",
    "tag=${tag}\ncontrol=${control}\ncommand=0x41\noutput=0x0B\nexpected=Out8<-InD\nframes=${frames}\nwrites=${writes}\nresponses=${responses}\ngainAll=${allCount}\nseriesCount=${seriesCount}\nchangingOffsets=${offsets}\nallGainChangingOffsets=${allOffsets}\nlastInteresting=${last}\n"
);

saveText("${base}/last-write.txt", last);
saveText("${base}/recent-interesting-writes.txt", recent);
saveText("${base}/gain-all-payload-series.txt", payloadSeries(gainAll));
saveText("${base}/gain-all-changing-offsets.txt", allOffsets);
saveText("${base}/gain-out8-payload-series.txt", payloadSeries(series));
saveText("${base}/gain-out8-changing-offsets.txt", offsets);
saveText("${base}/gain-out8-u16-at-4.txt", u16Series(series, 4));
saveText("${base}/gain-out8-u16-at-5.txt", u16Series(series, 5));
saveText("${base}/gain-out8-u16-at-6.txt", u16Series(series, 6));

print("done");
print("saved=${base}");
print("seriesCount=${seriesCount}");
print(offsets);
