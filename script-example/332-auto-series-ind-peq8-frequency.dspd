let tag = "ind-peq8-frequency-series";
let base = "out/fader/${tag}";
let control = "frequency";
let command = 0x33;
let channel = 0x03;
let band = 0x07;

guiConnect();

let cap = guiActionCapture(
    "On the PEQ page for InD, change only PEQ8 Frequency across several values now.",
    60000,
    3000,
    15000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 60, 0x40);
let peqAll = writesByCommand(cap, command);
let series = writesByCommandAndChannel(cap, command, channel);

let frames = cap.totalFrames;
let writes = cap.writeCount;
let responses = cap.responseCount;
let peqAllCount = len(peqAll);
let seriesCount = len(series);
let offsets = changingOffsetsAcrossWrites(series);
let allOffsets = changingOffsetsAcrossWrites(peqAll);

saveText("${base}/summary.txt",
    "tag=${tag}\ncontrol=${control}\ncommand=0x33\nchannel=0x03\nband=0x07\nexpectedOffset=8\nframes=${frames}\nwrites=${writes}\nresponses=${responses}\npeqAll=${peqAllCount}\nseriesCount=${seriesCount}\nchangingOffsets=${offsets}\nallPeqChangingOffsets=${allOffsets}\nlastInteresting=${last}\n"
);

saveText("${base}/last-write.txt", last);
saveText("${base}/recent-interesting-writes.txt", recent);
saveText("${base}/peq-all-payload-series.txt", payloadSeries(peqAll));
saveText("${base}/peq-all-changing-offsets.txt", allOffsets);
saveText("${base}/peq-ind-payload-series.txt", payloadSeries(series));
saveText("${base}/peq-ind-changing-offsets.txt", offsets);
saveText("${base}/peq-ind-u16-at-6.txt", u16Series(series, 6));
saveText("${base}/peq-ind-u16-at-8.txt", u16Series(series, 8));
saveText("${base}/peq-ind-u16-at-10.txt", u16Series(series, 10));
saveText("${base}/peq-ind-u16-at-11.txt", u16Series(series, 11));

print("done");
print("saved=${base}");
print("seriesCount=${seriesCount}");
print(offsets);
