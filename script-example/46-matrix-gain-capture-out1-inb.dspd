let tag = "matrix-gain-out1-inb";

guiConnect();

let cap = guiActionCapture(
    "Move the matrix gain for Out1 <- InB a small amount (e.g., 0.0 dB to -1.0 dB). The capture auto-starts on the first real GUI write and auto-finishes after the motion settles.",
    45000,
    1400,
    8000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 60, 0x40);
let readCount = len(cap.readBlockResponses);

saveText("out/matrix/${tag}/summary.txt",
    "tag=${tag}\n"
    + "frames=" + cap.totalFrames + "\n"
    + "writes=" + cap.writeCount + "\n"
    + "responses=" + cap.responseCount + "\n"
    + "readBlockResponses=" + readCount + "\n"
    + "lastInteresting=" + last + "\n"
);

saveText("out/matrix/${tag}/last-write.txt", last);
saveText("out/matrix/${tag}/recent-interesting-writes.txt", recent);

if (readCount > 0) {
    saveCaptureReadBlocks(cap, "out/matrix/${tag}/blocks");
}

print("done");
print(last);
