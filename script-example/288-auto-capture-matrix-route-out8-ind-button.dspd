let tag = "matrix-route-out8-ind-button";
let base = "out/fader/${tag}";
let control = "route_button";
let command = 0x3A;
let output = 0x0B;

guiConnect();

let cap = guiActionCapture(
    "On the Matrix page, click only the Out8 <- InD route button once.",
    60000,
    2500,
    12000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 40, 0x40);
let routeAll = writesByCommand(cap, command);
let series = writesByCommandAndChannel(cap, command, output);

let frames = cap.totalFrames;
let writes = cap.writeCount;
let responses = cap.responseCount;
let allCount = len(routeAll);
let seriesCount = len(series);
let offsets = changingOffsetsAcrossWrites(series);
let allOffsets = changingOffsetsAcrossWrites(routeAll);

saveText("${base}/summary.txt",
    "tag=${tag}\ncontrol=${control}\ncommand=0x3A\noutput=0x0B\nexpected=Out8<-InD\nframes=${frames}\nwrites=${writes}\nresponses=${responses}\nrouteAll=${allCount}\nseriesCount=${seriesCount}\nchangingOffsets=${offsets}\nallRouteChangingOffsets=${allOffsets}\nlastInteresting=${last}\n"
);

saveText("${base}/last-write.txt", last);
saveText("${base}/recent-interesting-writes.txt", recent);
saveText("${base}/route-all-payload-series.txt", payloadSeries(routeAll));
saveText("${base}/route-all-changing-offsets.txt", allOffsets);
saveText("${base}/route-out8-payload-series.txt", payloadSeries(series));
saveText("${base}/route-out8-changing-offsets.txt", offsets);
saveText("${base}/route-out8-u16-at-4.txt", u16Series(series, 4));
saveText("${base}/route-out8-u16-at-5.txt", u16Series(series, 5));

print("done");
print("saved=${base}");
print("seriesCount=${seriesCount}");
print(offsets);
