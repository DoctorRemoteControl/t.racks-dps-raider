# Decode FIR408 matrix gain readback by all-crosspoint gain dump diff.

let base = "out/read-decode/all-matrix-gains-dumpdiff";

connect();
resetSession();
ensureSession();
handshake();

# Before: all matrix gains at -60.0 dB raw 0.
write("00 01 05 41 04 00 00 00");
write("00 01 05 41 04 01 00 00");
write("00 01 05 41 04 02 00 00");
write("00 01 05 41 04 03 00 00");
write("00 01 05 41 05 00 00 00");
