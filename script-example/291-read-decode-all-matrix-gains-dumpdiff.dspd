write("00 01 05 41 0A 03 3C 00");
write("00 01 05 41 0B 00 18 01");
write("00 01 05 41 0B 01 0E 01");
write("00 01 05 41 0B 02 50 00");
write("00 01 05 41 0B 03 3C 00");
sleep(500);

let after = readSaveConfig("${base}/after-pattern", 0x00, 0x1C);

saveDiffReport("${base}/assembled-diff-report.txt", assembledData(before), assembledData(after));
saveText("${base}/pattern-summary.txt",
    "Matrix gain dump diff\nbefore: all crosspoints -60.0dB raw=0\nafter: InA=0.0dB raw=280, InB=-1.0dB raw=270, InC=-20.0dB raw=80, InD=-30.0dB raw=60\ncommand: 00 01 05 41 <output_channel> <input_index> <gain_lo> <gain_hi>\n"
);

# Restore all matrix gains to +0.0 dB as shown in the user's screenshot.
write("00 01 05 41 04 00 18 01");
write("00 01 05 41 04 01 18 01");
