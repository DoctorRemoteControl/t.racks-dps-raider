write("00 01 05 41 0B 00 00 00");
write("00 01 05 41 0B 01 00 00");
write("00 01 05 41 0B 02 00 00");
write("00 01 05 41 0B 03 00 00");
sleep(500);

let before = readSaveConfig("${base}/before-all-minus60", 0x00, 0x1C);

# After: repeatable per-input test pattern.
# InA = 0.0 dB raw 280, InB = -1.0 dB raw 270, InC = -20.0 dB raw 80, InD = -30.0 dB raw 60.
write("00 01 05 41 04 00 18 01");
write("00 01 05 41 04 01 0E 01");
write("00 01 05 41 04 02 50 00");
write("00 01 05 41 04 03 3C 00");
write("00 01 05 41 05 00 18 01");
write("00 01 05 41 05 01 0E 01");
write("00 01 05 41 05 02 50 00");
write("00 01 05 41 05 03 3C 00");
