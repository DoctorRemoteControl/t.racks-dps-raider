let base = "out/read-decode/matrix-gain-out8-ind";

connect();
resetSession();
ensureSession();
handshake();

for (let i in 0..28) {
    write("00 01 05 41 0B 03 0E 01");
    sleep(180);
    let minus1 = readBlock(i);

    write("00 01 05 41 0B 03 3C 00");
    sleep(180);
    let minus30 = readBlock(i);

    let offsets = changedOffsets(minus1.payload, minus30.payload);
    if (len(offsets) > 0) {
        saveText("${base}/block-${i}-minus1.hex.txt", minus1.payloadHex);
        saveText("${base}/block-${i}-minus30.hex.txt", minus30.payloadHex);
        saveText("${base}/block-${i}-changed-offsets.txt", offsets);
        saveText("${base}/block-${i}-diff-bytes.txt", diffBytes(minus1.payload, minus30.payload));
        saveText("${base}/block-${i}-diff-u16le.txt", diffU16le(minus1.payload, minus30.payload));
        saveDiffReport("${base}/block-${i}-diff-report.txt", minus1.payload, minus30.payload);
        print("changed-block ${i}");
        print(offsets);
    }
}

print("matrix-gain-out8-ind-read-decode-done");
