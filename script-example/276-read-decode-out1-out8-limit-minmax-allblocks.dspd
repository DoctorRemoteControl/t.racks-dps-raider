# Decode FIR408 output limiter readback locations by controlled min -> max writes.
# The write frame layout comes from stable Out1/Out5/Out8 GUI captures.

let base = "out/read-decode/out1-out8-limit-minmax";

connect();
resetSession();
ensureSession();
handshake();

# Min GUI state:
# ratio=0 (1:1.0), attack=0 (1 ms), release=9 (10 ms), knee=0, threshold=0 (-90 dB).
#
# Max GUI state:
# ratio=15 (Limit), attack=998 (999 ms), release=2999 (3000 ms), knee=12, threshold=220 (+20 dB).

let out1Min = "00 01 0C 3F 04 00 00 00 00 09 00 00 00 00 00";
let out1Max = "00 01 0C 3F 04 0F 00 E6 03 B7 0B 0C 00 DC 00";

let out8Min = "00 01 0C 3F 0B 00 00 00 00 09 00 00 00 00 00";
let out8Max = "00 01 0C 3F 0B 0F 00 E6 03 B7 0B 0C 00 DC 00";

saveText("${base}/pattern-summary.txt",
    "Output Limit min/max read decode\n"
    + "min: ratio=0 attack=0 release=9 knee=0 threshold=0\n"
    + "max: ratio=15 attack=998 release=2999 knee=12 threshold=220\n"
    + "Out1 min=${out1Min}\nOut1 max=${out1Max}\n"
    + "Out8 min=${out8Min}\nOut8 max=${out8Max}\n"
);

for (let i in 0..28) {
    write(out1Min);
    sleep(150);
    let before = readBlock(i);

    write(out1Max);
    sleep(150);
    let after = readBlock(i);

    let offsets = changedOffsets(before.payload, after.payload);
    if (len(offsets) > 0) {
        saveText("${base}/out1/block-${i}-before.hex.txt", before.payloadHex);
        saveText("${base}/out1/block-${i}-after.hex.txt", after.payloadHex);
        saveText("${base}/out1/block-${i}-changed-offsets.txt", offsets);
        saveText("${base}/out1/block-${i}-diff-bytes.txt", diffBytes(before.payload, after.payload));
        saveText("${base}/out1/block-${i}-diff-u16le.txt", diffU16le(before.payload, after.payload));
        saveDiffReport("${base}/out1/block-${i}-diff-report.txt", before.payload, after.payload);
        print("out1 changed-block ${i}");
        print(offsets);
    }
}

for (let i in 0..28) {
    write(out8Min);
    sleep(150);
    let before = readBlock(i);

    write(out8Max);
    sleep(150);
    let after = readBlock(i);

    let offsets = changedOffsets(before.payload, after.payload);
    if (len(offsets) > 0) {
        saveText("${base}/out8/block-${i}-before.hex.txt", before.payloadHex);
        saveText("${base}/out8/block-${i}-after.hex.txt", after.payloadHex);
        saveText("${base}/out8/block-${i}-changed-offsets.txt", offsets);
        saveText("${base}/out8/block-${i}-diff-bytes.txt", diffBytes(before.payload, after.payload));
        saveText("${base}/out8/block-${i}-diff-u16le.txt", diffU16le(before.payload, after.payload));
        saveDiffReport("${base}/out8/block-${i}-diff-report.txt", before.payload, after.payload);
        print("out8 changed-block ${i}");
        print(offsets);
    }
}

print("out1-out8-limit-minmax-read-decode-done");
